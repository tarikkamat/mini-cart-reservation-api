APP_NAME="Mini Cart Reservation API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Database (PostgreSQL) ---
# DB_HOST=postgres targets the service inside the Compose network. When
# deploying to a managed Postgres instance, replace with the public/private
# host from your provider and rotate the password through your secret store.
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=mini_cart
DB_USERNAME=mini_cart
DB_PASSWORD=replace-via-secret-store

# --- Redis ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace-via-secret-store
REDIS_DB=0
REDIS_CACHE_DB=1

# --- Cache / Sessions / Queue ---
CACHE_STORE=redis
CACHE_PREFIX=mini_cart_cache
SESSION_DRIVER=redis
SESSION_CONNECTION=default
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

QUEUE_CONNECTION=redis
HORIZON_PREFIX=mini_cart_horizon

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Reservation domain ---
RESERVATION_TTL_MINUTES=15
IDEMPOTENCY_TTL_HOURS=24

# --- Entrypoint behavior (consumed by docker/entrypoint.sh) ---
RUN_MIGRATIONS=true
RUN_DB_SEED=false
OPTIMIZE_ON_BOOT=true
DB_WAIT_RETRIES=30

# --- Queue worker tuning ---
QUEUE_TRIES=3
QUEUE_TIMEOUT=90
QUEUE_SLEEP=3
QUEUE_MAX_JOBS=1000
QUEUE_MAX_TIME=3600

# --- Mail (replace with real provider in production) ---
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_SCHEME=null
MAIL_FROM_ADDRESS="no-reply@your-domain.example"
MAIL_FROM_NAME="${APP_NAME}"

# --- AWS (optional, S3/SES) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- PHP-FPM / OPcache ---
PHP_MEMORY_LIMIT=512M
PHP_OPCACHE_MEMORY_CONSUMPTION=256
PHP_OPCACHE_MAX_ACCELERATED_FILES=20000
PHP_OPCACHE_VALIDATE_TIMESTAMPS=0

# --- Container / nginx ---
NGINX_HTTP_PORT=80
REDIS_MAXMEMORY=256mb
